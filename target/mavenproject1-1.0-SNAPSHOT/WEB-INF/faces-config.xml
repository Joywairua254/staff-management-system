<?xml version="1.0" encoding="UTF-8"?>
<faces-config xmlns="http://xmlns.jcp.org/xml/ns/javaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                                  http://xmlns.jcp.org/xml/ns/javaee/web-facesconfig_2_3.xsd"
              version="2.3">

    <navigation-rule>
        <from-view-id>/dashboard.xhtml</from-view-id>

        <!-- Staff -->
        <navigation-case>
            <from-outcome>staffList</from-outcome>
            <to-view-id>/stafflist.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>staffCreate</from-outcome>
            <to-view-id>/staffcreate.xhtml</to-view-id>
            <redirect/>
        </navigation-case>

        <!-- Roles -->
        <navigation-case>
            <from-outcome>rolesList</from-outcome>
            <to-view-id>/rolelist.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>roleCreate</from-outcome>
            <to-view-id>/rolecreate.xhtml</to-view-id>
            <redirect/>
        </navigation-case>

        <!-- Departments -->
        <navigation-case>
            <from-outcome>departmentsList</from-outcome>
            <to-view-id>/departmentlist.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>departmentCreate</from-outcome>
            <to-view-id>/departmentcreate.xhtml</to-view-id>
            <redirect/>
        </navigation-case>

        <!-- Attendance -->
        <navigation-case>
            <from-outcome>attendanceList</from-outcome>
            <to-view-id>/attendancelist.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>attendanceCreate</from-outcome>
            <to-view-id>/attendancecreate.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
    </navigation-rule>
</faces-config>
